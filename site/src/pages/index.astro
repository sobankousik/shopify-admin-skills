    .gh-text { display: none; }
    .gh-top svg { width: 18px; height: 18px; margin: 0; }
  }

  /* HERO */
  .hero {
    height: 100vh;
    display: flex;
    align-items: center;
    padding: 0;
    overflow: hidden;
  }

  .hero-split {
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    padding: 0 40px; box-sizing: border-box;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    height: 100%;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
  }

  .line {
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 0.88;
  }

  .typewriter {
    display: inline-block;
    white-space: nowrap;
