  .typewriter.reveal {
    animation: typeReveal 0.8s steps(12, end) forwards;
  }

  @keyframes typeReveal {
    0% { clip-path: inset(-20% 100% -20% 0); opacity: 1; }
    100% { clip-path: inset(-20% 0 -20% 0); opacity: 1; }
  }

  .stroke {
    -webkit-text-stroke: 3px var(--color-dark);
    color: transparent;
  }

  .dot { color: var(--color-accent); }

  .hero-sub {
    margin-top: 24px;
    font-size: 1.1rem;
    color: var(--color-muted);
    max-width: 500px;
    line-height: 1.5;
    min-height: 1.6em;
  }

  .hero-sub-static {
    font-size: 1.1rem;
    color: var(--color-muted);
    margin-top: 4px;
  }

  #rotating-link {
    text-decoration: none;
    cursor: pointer;
  }

  #rotating-link:hover #rotating-text {
    background: linear-gradient(to top, rgba(232, 168, 56, 0.45) 40%, transparent 40%);
  }

  #rotating-text {
    color: var(--color-dark);
    font-weight: 600;
    font-size: 1.2rem;
    transition: opacity 0.3s, background 0.2s;
    border-right: 2px solid var(--color-accent);
    padding-right: 3px;
    animation: blink 0.8s step-end infinite;
    background: linear-gradient(to top, rgba(232, 168, 56, 0.2) 40%, transparent 40%);
    padding-bottom: 2px;
  }

  @keyframes blink {
    50% { border-color: transparent; }
  }

  .hero-cta { margin-top: 28px; }

  .install-tabs {
    display: inline-flex;
    gap: 4px;
    margin-bottom: 12px;
    padding: 4px;
    background: rgba(0, 0, 0, 0.04);
    border-radius: 10px;
  }

  .tab {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 7px 14px;
    border: none;
